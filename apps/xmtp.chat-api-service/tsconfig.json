{
  "compilerOptions": {
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    // this is needed for the vercel runtime
    "moduleResolution": "node",
    "noEmit": true,
    "paths": {
      "@/*": ["./src/*"],
      "@zod/*": ["./prisma/generated/zod/*"]
    },
    "preserveConstEnums": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ESNext",
    "types": ["vitest/globals"]
  },
  "include": [
    "rollup.config.js",
    "src/**/*",
    "prisma/**/*",
    "vitest.config.ts",
    "test/**/*"
  ]
}
